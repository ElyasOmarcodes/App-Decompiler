.class public interface abstract annotation Ll/ۥ۠ۨۥ;
.super Ljava/lang/Object;
.source "KAUK"

# interfaces
.implements Ljava/lang/annotation/Annotation;


# annotations
.annotation runtime Ljava/lang/annotation/Retention;
